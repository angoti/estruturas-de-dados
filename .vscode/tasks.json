{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Java: Compilar arquivo atual (UTF-8)",
      "type": "shell",
      "command": "javac",
      "args": [
        "-encoding",
        "UTF-8",
        "-d",
        "${workspaceFolder}",
        "${file}"
      ],
      "group": "build",
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "Java: Compilar TesteVazamentoMemoria (UTF-8)",
      "type": "shell",
      "command": "javac",
      "args": [
        "-encoding",
        "UTF-8",
        "-d",
        "${workspaceFolder}",
        "${workspaceFolder}\\arraysdinamicos\\TesteVazamentoMemoria.java"
      ],
      "group": "build",
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "Java: Executar TesteVazamentoMemoria (UTF-8)",
      "type": "shell",
      "command": "java",
      "args": [
        "-Dfile.encoding=UTF-8",
        "-Xmx600m",
        "-cp",
        "${workspaceFolder}",
        "arraysdinamicos.TesteVazamentoMemoria"
      ],
      "dependsOn": "Java: Compilar TesteVazamentoMemoria (UTF-8)",
      "problemMatcher": []
    }
  ]
}